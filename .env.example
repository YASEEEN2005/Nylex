# SMTP Configuration for Automated Emails
# You can use a service like Gmail, SendGrid, Amazon SES, etc.
# For Gmail, you will need to create an "App Password" if you have 2FA enabled.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Your email address (e.g., yourname@gmail.com)
SMTP_USER=your_email@gmail.com

# Your email password or app password
SMTP_PASS=your_app_password

# Email address where you want to receive notifications (defaults to SMTP_USER if not provided)
ADMIN_EMAIL=admin_email@gmail.com
